{
  "dashboard": {
    "id": null,
    "title": "DevOps Monitoring Dashboard",
    "tags": ["devops"],
    "timezone": "browser",
    "panels": [
      {
        "type": "graph",
        "title": "CPU Usage (Example)",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[1m])",
            "legendFormat": "CPU"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "type": "graph",
        "title": "Memory Usage (Example)",
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Memory"
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        }
      }
    ],
    "schemaVersion": 30,
    "version": 1
  }
}
